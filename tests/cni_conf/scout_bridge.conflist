{
  "name": "scout_bridge",
  "cniVersion": "1.1.0",
  "plugins": [
    {
      "type": "bridge",
      "bridge": "scout-br0",
      "isDefaultGateway": true,
      "forceAddress": false,
      "ipMasq": true,
      "hairpinMode": true,
      "mtu": 1500,
      "ipam": {
        "type": "host-local",
        "subnet": "192.168.13.0/24",
        "resolvConf": "/etc/resolv.conf",
        "dataDir": "./cni_networks"
      }
    },
    {
      "type": "firewall"
    },
    {
      "type": "tc-redirect-tap"
    },
    {
      "type": "loopback"
    }
  ]
}
