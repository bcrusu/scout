COMPOSE_PROJECT_NAME=scout

SCOUT_CONTROL_IMAGE=scout/control:latest
SCOUT_DATA_IMAGE=scout/data:latest
SCOUT_API_IMAGE=scout/api:latest

SCOUT_API_PORT=11001
SCOUT_DATA_REPLICAS=10
SCOUT_API_REPLICAS=3

OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.112.0
OTEL_COLLECTOR_HOST=otelcol
OTEL_COLLECTOR_PORT_GRPC=4317
OTEL_COLLECTOR_PORT_HTTP=4318

GRAFANA_IMAGE=grafana/grafana:11.3.0
GRAFANA_SERVICE_PORT=3000
GRAFANA_SERVICE_HOST=grafana

JAEGER_IMAGE=jaegertracing/all-in-one:1.62.0
JAEGER_SERVICE_PORT=16686
JAEGER_SERVICE_HOST=jaeger

PROMETHEUS_IMAGE=prom/prometheus:v2.55.0
PROMETHEUS_SERVICE_PORT=9090
PROMETHEUS_SERVICE_HOST=prometheus
PROMETHEUS_ADDR=${PROMETHEUS_SERVICE_HOST}:${PROMETHEUS_SERVICE_PORT}

NGINX_IMAGE=nginx:1.27.2-alpine3.20
NGINX_PORT=11001
